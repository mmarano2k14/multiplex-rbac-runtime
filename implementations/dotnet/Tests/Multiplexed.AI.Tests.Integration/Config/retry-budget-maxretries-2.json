{
  "pipelines": [
    {
      "name": "retry-budget-maxretries-2",
      "version": "1",
      "executionMode": "Dag",
      "steps": [
        {
          "name": "start",
          "stepKey": "debug-retry-fail",
          "order": 1,
          "config": {
            "retry": {
              "policies": [ "retry.transient.default" ],
              "maxRetries": 2,
              "strategy": "Fixed",
              "baseDelayMs": 50
            }
          }
        }
      ]
    }
  ]
}