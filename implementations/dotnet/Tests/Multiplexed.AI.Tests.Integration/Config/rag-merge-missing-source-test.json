{
  "pipelines": [
    {
      "name": "rag-merge-missing-source-test",
      "version": "1",
      "executionMode": "Dag",
      "steps": [
        {
          "name": "candidate",
          "stepKey": "rag.retrieval",
          "order": 1,
          "input": {
            "candidateId": "state.candidateId"
          },
          "config": {
            "operation": "candidate.byId",
            "provider": "relational",
            "providerKey": "sqlserver",
            "executionMode": "provider"
          }
        },
        {
          "name": "merge",
          "stepKey": "rag.merge",
          "order": 2,
          "dependsOn": [
            "candidate"
          ],
          "config": {
            "sourceSteps": [
              "candidate",
              "missing-step"
            ]
          }
        }
      ]
    }
  ]
}